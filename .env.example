APP_NAME=Laravel
APP_ENV=local
APP_KEY=test1234
APP_DEBUG=true
APP_URL=http://localhost
# Frontend origin for CORS (e.g. Vite dev server or production client URL)
# FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Filament /login: max wrong passwords per email+IP before lockout; lockout window in seconds
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_DECAY_SECONDS=120

# Broadcasting: "pusher" for real-time; "log" to disable (bookings still work, no WebSocket)
BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local

# Pusher (broadcasting driver)
# If you're using Pusher.com, you can usually leave PUSHER_HOST empty and just set the cluster + credentials.
PUSHER_APP_ID=marcelinos-app
PUSHER_APP_KEY=local-key
PUSHER_APP_SECRET=local-secret
PUSHER_APP_CLUSTER=ap1
PUSHER_HOST=api-ap1.pusher.com
PUSHER_PORT=443
PUSHER_SCHEME=https
# Optional: override the TLS port used by websocket clients.
PUSHER_WSS_PORT=443
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

API_KEY=

# Booking cancel/reschedule OTP (email): after N sends, wait cooldown seconds
# BOOKING_ACTION_OTP_MAX_SENDS=3
# BOOKING_ACTION_OTP_COOLDOWN_SECONDS=60
